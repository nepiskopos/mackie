# Web search (required)
TAVILY_API_KEY=tvly-...

# Provider API keys — set at least one.
# When multiple keys are present, priority is: Anthropic > OpenAI > xAI > Google.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
XAI_API_KEY=xai-...
GEMINI_API_KEY=AIza...

# Model to use per provider — leave blank to use the default shown.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
OPENAI_MODEL=gpt-4o-mini
XAI_MODEL=xai/grok-3-mini
GEMINI_MODEL=gemini/gemini-2.0-flash